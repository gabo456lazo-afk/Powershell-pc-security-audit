# Reportes reales generados por los scripts
reports/*
!reports/.gitkeep

# Reportes forenses V2 generados localmente
reports-forensic-v2/*
!reports-forensic-v2/.gitkeep

# Archivos temporales
*.log
*.tmp
*.bak

# Reportes exportados
*.csv
*.json
*.xml
*.txt

# Archivos comprimidos
*.zip
*.rar
*.7z

# Sistema operativo
.DS_Store
Thumbs.db

# PowerShell
*.ps1xml
*.pssc
*.psrc
